---
// Root route: static sites can't run middleware, so language detection runs
// on the client. Pick locale from the `lan` cookie, else navigator.language,
// then replace into /<locale>. (Ported from the old Next middleware proxy.js.)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>mogumogu's blog</title>
    <script is:inline>
      (() => {
        const locales = ["en", "ja", "ko"];
        const fallback = "ko";

        const fromCookie = () => {
          const match = document.cookie.match(/(?:^|;\s*)lan=([^;]+)/);
          return match && locales.includes(match[1]) ? match[1] : null;
        };

        const fromNavigator = () => {
          const langs = navigator.languages || [navigator.language || ""];
          for (const lang of langs) {
            const code = String(lang).slice(0, 2).toLowerCase();
            if (locales.includes(code)) return code;
          }
          return fallback;
        };

        const lan = fromCookie() || fromNavigator();
        document.cookie = `lan=${lan}; path=/; max-age=${60 * 60 * 24 * 30}`;
        window.location.replace(`/${lan}`);
      })();
    </script>
  </head>
  <body></body>
</html>
