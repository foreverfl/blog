---
import Base from "../../../../layouts/Base.astro";
import SlugIsland from "@/components/islands/SlugIsland";
import TrendsIsland from "@/components/islands/TrendsIsland";
import classifications from "@/public/category.json";
import { buildExcerpt } from "@/lib/markdown/excerpt";
import { getContentsStructure } from "@/lib/content/jsonHelpers";

// NOTE: Astro hoists getStaticPaths out of the frontmatter, so anything it
// uses must live inside it (frontmatter consts are not in scope here).
// Module imports are fine — they are module-scoped, not frontmatter-scoped.
export async function getStaticPaths() {
  const RUST_API =
    import.meta.env.PUBLIC_API_RUST_URL || "http://localhost:8002";

  const langs = ["en", "ko", "ja"];
  const perPage = 100;
  const paths = [];

  for (const lan of langs) {
    for (const classification of classifications) {
      // trends is R2-backed: slugs (dates) and content come from R2 JSON,
      // not the DB. Every other classification is a DB-backed article.
      const isR2Backed = classification.link === "trends";
      if (isR2Backed) {
        for (const category of classification.categories) {
          // List the R2 bucket to collect available dates (= slugs).
          let structure: { folder: string; dates: string[] }[] = [];
          try {
            structure = await getContentsStructure(category.link);
          } catch {
            structure = [];
          }

          let digestTitle = "해커뉴스 요약";
          if (lan === "ja") digestTitle = "ハッカーニュースダイジェスト";
          else if (lan === "en") digestTitle = "Hacker News Digest";

          const r2Base = import.meta.env.PUBLIC_R2_URI || "";

          for (const group of structure) {
            for (const date of group.dates) {
              const yyyymmdd = date.replace(/-/g, "");
              paths.push({
                params: {
                  lan,
                  classification: classification.link,
                  category: category.link,
                  slug: date,
                },
                props: {
                  title: `${digestTitle} (${date})`,
                  description: `${digestTitle} — ${date}`,
                  image: r2Base
                    ? `${r2Base}/hackernews-images/${yyyymmdd}.png`
                    : "",
                },
              });
            }
          }
        }
        continue;
      }

      for (const category of classification.categories) {
        // Collect every slug in this category (paginate via total).
        const slugs: string[] = [];
        let page = 1;
        let total = Infinity;
        while ((page - 1) * perPage < total) {
          const listUrl = `${RUST_API}/posts/${classification.link}/${category.link}?lang=${lan}&page=${page}&per_page=${perPage}`;
          const res = await fetch(listUrl).catch(() => null);
          if (!res || !res.ok) break;
          const data = await res.json();
          total = data.total ?? 0;
          for (const post of data.posts ?? []) slugs.push(post.slug);
          if (!data.posts || data.posts.length === 0) break;
          page++;
        }

        // Fetch each post once for build-time SEO meta (title/excerpt/image).
        for (const slug of slugs) {
          let title = slug;
          let description = "";
          let image = "";
          const detailUrl = `${RUST_API}/posts/${classification.link}/${category.link}/${slug}?lang=${lan}`;
          const res = await fetch(detailUrl).catch(() => null);
          if (res && res.ok) {
            const post = await res.json();
            image = post.image ?? "";
            const content = post.contents?.[0];
            title = content?.title || slug;
            description = buildExcerpt(content?.body_markdown);
          }
          paths.push({
            params: {
              lan,
              classification: classification.link,
              category: category.link,
              slug,
            },
            props: { title, description, image },
          });
        }
      }
    }
  }

  return paths;
}

const { lan, classification } = Astro.params;
const { title, description, image } = Astro.props;
const pageTitle = title ? `${title} | mogumogu's blog` : "mogumogu's blog";
const isTrends = classification === "trends";
---

<Base lang={lan} title={pageTitle} description={description} image={image}>
  {
    isTrends ? (
      <TrendsIsland client:only="react" />
    ) : (
      <SlugIsland client:only="react" />
    )
  }
</Base>
